# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp

# MLflow
mlruns/
mlartifacts/

# Models — large binary artifacts, regenerated by training
models/*.joblib
models/*.pkl

# DVC — managed data files are tracked via .dvc pointers, not raw
/data/*
!/data/.gitkeep
!/data/*.dvc

# Local DVC cache (project-scoped)
.dvc/cache
.dvc/tmp
.dvc/plots

# Reports — generated outputs (keep markdown source)
reports/screenshots/*.png
reports/screenshots/*.jpg
!reports/screenshots/.gitkeep

# Logs
*.log
